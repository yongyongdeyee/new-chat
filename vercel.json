{
  "buildCommand": "npm --prefix frontend run build",
  "installCommand": "npm --prefix frontend install && pip install -r requirements.txt",
  "outputDirectory": "frontend/dist",
  "functions": {
    "app.py": {
      "excludeFiles": "{frontend/node_modules/**,frontend/dist/**,backend/.venv/**,backend/test_api.py,**/__pycache__/**,**/*.pyc}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/app.py"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
